# Git 忽略文件配置

# ==================== 环境配置 ====================
.env
.env.local
.env.*.local

# ==================== Python ====================
# 字节码文件
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境
venv/
env/
ENV/
.venv

# ==================== IDE ====================
# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml

# ==================== 日志文件 ====================
*.log
logs/

# ==================== 临时文件 ====================
*.tmp
*.temp
.DS_Store
Thumbs.db

# ==================== 敏感数据 ====================
# API Keys 等
*.key
*.pem
*.crt
# 不提交实际数据库文件（Cloud SQL 为主数据库）
*.db
app.db
# 动态配置文件（含密码）
settings.json

# ==================== 前端构建产物 ====================
# CD 模式：前端在云端编译，无需提交 dist
frontend/dist/
frontend/node_modules/

# ==================== 备份文件 ====================
backups/

# ==================== ngrok ====================
ngrok
ngrok.exe
