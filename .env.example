# 环境变量配置模板
# 
# 使用说明:
# 1. 复制此文件并重命名为 .env
# 2. 填写实际的 API 密钥和配置值
# 3. 不要将 .env 文件提交到版本控制系统

# ==================== API 密钥 ====================
# Google Gemini API 密钥
# 获取地址: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyDvH-7dYWAMpCCoqt15-JsdTcV-VxE3cYc

# AutoAddress API 密钥 (爱尔兰地址验证服务)
# 获取地址: https://www.autoaddress.com/
AUTOADDRESS_API_KEY=pub_b5732e69-955f-4ced-ad15-c17755dca6a3

# ==================== 电话配置 ====================
# 转接电话号码 (爱尔兰格式: +353XXXXXXXXX)
TRANSFER_PHONE_NUMBER=+353419816853

# ==================== 可选配置 ====================
# 以下配置有默认值，可以不设置

# 服务器主机地址 (默认: 0.0.0.0)
# SERVER_HOST=0.0.0.0

# 服务器端口 (默认: 8000)
# SERVER_PORT=8000

# AI 模型名称 (默认: models/gemini-2.5-flash-native-audio-preview-12-2025)
# MODEL_NAME=models/gemini-2.5-flash-native-audio-preview-12-2025

# AI 语音名称 (默认: Aoede)
# VOICE_NAME=Aoede
